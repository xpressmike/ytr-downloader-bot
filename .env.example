# Copy this file to `.env` and fill in the values.
# `chmod 600 .env` after editing.

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:REPLACE_WITH_YOUR_BOT_TOKEN

# Comma-separated list of allowed Telegram chat IDs.
# Get your chat_id by sending any message to @userinfobot or similar.
# The first ID in the list is the default recipient for outbound messages;
# additional IDs can interact with the bot too.
TELEGRAM_ALLOWED_CHAT_IDS=123456789
